rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidMovie(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 300
        && data.genre is string && data.genre.size() <= 60
        && data.year is string && data.year.size() <= 10
        && data.status in ['to-watch', 'watched']
        && data.rating is number && data.rating >= 0 && data.rating <= 5
        && (!('director' in data) || data.director == null || (data.director is string && data.director.size() <= 200))
        && (!('comment' in data) || data.comment == null || (data.comment is string && data.comment.size() <= 2000))
        && (!('posterUrl' in data) || data.posterUrl == null || (data.posterUrl is string && data.posterUrl.size() <= 500));
    }

    function isValidProfile(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('username' in data) || (data.username is string && data.username.size() <= 20));
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /profiles/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid && isValidProfile(request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid && isValidProfile(request.resource.data);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    match /friendships/{pairId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.uidA || request.auth.uid == resource.data.uidB);
      allow create: if request.auth != null
        && request.resource.data.status == 'pending'
        && request.resource.data.requestedBy == request.auth.uid
        && (request.auth.uid == request.resource.data.uidA || request.auth.uid == request.resource.data.uidB)
        && request.resource.data.uidA < request.resource.data.uidB
        && pairId == request.resource.data.uidA + '_' + request.resource.data.uidB;
      allow update: if request.auth != null
        && resource.data.status == 'pending'
        && request.auth.uid != resource.data.requestedBy
        && (request.auth.uid == resource.data.uidA || request.auth.uid == resource.data.uidB)
        && request.resource.data.status == 'accepted'
        && request.resource.data.uidA == resource.data.uidA
        && request.resource.data.uidB == resource.data.uidB
        && request.resource.data.requestedBy == resource.data.requestedBy;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.uidA || request.auth.uid == resource.data.uidB);
    }

    match /users/{uid}/movies/{movieId} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        (
          exists(/databases/$(database)/documents/friendships/$(request.auth.uid < uid ? request.auth.uid + '_' + uid : uid + '_' + request.auth.uid)) &&
          get(/databases/$(database)/documents/friendships/$(request.auth.uid < uid ? request.auth.uid + '_' + uid : uid + '_' + request.auth.uid)).data.status == 'accepted'
        )
      );
      allow create: if request.auth != null && request.auth.uid == uid && isValidMovie(request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid && isValidMovie(request.resource.data);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
